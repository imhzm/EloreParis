APP_ENV=production
HOSTING_PROVIDER=hostinger_vps
NEXT_PUBLIC_SITE_URL=https://elore-paris.com

# Keep all gates false until the release packet has no blockers and the
# business owner explicitly approves the catalog, commerce, and indexing.
# Every one of these is read by the code and every one fails closed when absent
# — they are listed explicitly so an operator can see the full gate, rather than
# discovering a missing name from a 503.
PUBLIC_RELEASE_APPROVED=false
PUBLIC_CATALOG_APPROVED=false
PUBLIC_DISCOVERY_CONTENT_APPROVED=false
PUBLIC_EDITORIAL_CONTENT_APPROVED=false
PUBLIC_LEGAL_CONTENT_APPROVED=false
PUBLIC_COMMERCE_ENABLED=false

# Checkout quoting refuses with 503 policy_authority_unavailable until both of
# these name a real approved version. They are part of the commerce gate, not
# decoration: every quote and order records the versions it was agreed under.
PUBLIC_TERMS_VERSION=replace-with-approved-terms-version
PUBLIC_PRIVACY_NOTICE_VERSION=replace-with-approved-privacy-version

AUTHORITY_DB_PATH=/var/lib/elore-paris/authority.sqlite
RELEASE_EVIDENCE_PATH=/var/lib/elore-paris/release-evidence.json
OPS_AUDIT_FILE=/var/lib/elore-paris/ops-audit.json
PROMOTION_MEDIA_ROOT=/var/lib/elore-paris/media/promotions
ORDER_AUTHORITY_SECRET=replace-with-at-least-32-random-bytes

ENFORCE_OPS_ACCESS=true
OPS_AUTH_USERS_JSON=replace-with-generated-identity-json
OPS_ACCESS_SIGNING_SECRET=replace-with-at-least-32-random-bytes

AUTH_PROVIDER_CALLBACK_SECRET=replace-with-dedicated-random-secret
AUTH_PROVIDER_LABEL=Customer identity provider
AUTH_PROVIDER_ISSUER=https://replace-with-provider-issuer
AUTH_PROVIDER_AUTHORIZE_URL=https://replace-with-provider-authorize-url
AUTH_PROVIDER_TOKEN_URL=https://replace-with-provider-token-url
AUTH_PROVIDER_PROFILE_URL=https://replace-with-provider-profile-url
AUTH_PROVIDER_CLIENT_ID=replace-with-provider-client-id
AUTH_PROVIDER_CLIENT_SECRET=replace-with-provider-client-secret
AUTH_PROVIDER_SCOPE=openid profile email phone

# Provider callback HMAC signs the exact string: <unix-seconds>.<raw-json-body>.
PROVIDER_CALLBACK_HMAC_REQUIRED=true
PROVIDER_CALLBACK_MAX_SKEW_SECONDS=300
LIFECYCLE_COLLECTION_ENABLED=false
LIFECYCLE_CONSENT_POLICY_VERSION=replace-after-approved-privacy-review
LIFECYCLE_UNSUBSCRIBE_SECRET=replace-with-at-least-32-random-characters
LIFECYCLE_DELIVERY_ENABLED=false
LIFECYCLE_DELIVERY_PROVIDER_ENABLED=false
# Change to `aws-ses` only after SES identity, DKIM, suppression handling, and
# lifecycle release approval are complete.
LIFECYCLE_DELIVERY_PROVIDER_KEY=unassigned
LIFECYCLE_SES_REGION=me-south-1
LIFECYCLE_SES_FROM_EMAIL=lifecycle@elore-paris.com
LIFECYCLE_SES_CONFIGURATION_SET=elore-lifecycle-production
LIFECYCLE_SES_TIMEOUT_MS=10000
# Authorises inbound SNS on /api/providers/lifecycle/ses-sns: a message whose
# TopicArn does not match is rejected 403. Region must match LIFECYCLE_SES_REGION.
LIFECYCLE_SES_SNS_TOPIC_ARN=arn:aws:sns:me-south-1:000000000000:replace-with-lifecycle-topic

PAYMENT_PROVIDER_LABEL=Payment gateway
PAYMENT_PROVIDER_CALLBACK_SECRET=replace-with-dedicated-random-secret
PAYMENT_PROVIDER_BASE_URL=https://replace-with-provider-base-url
PAYMENT_PROVIDER_REQUEST_PATH=/payments/links
PAYMENT_PROVIDER_API_KEY=replace-with-provider-api-key
PAYMENT_PROVIDER_API_KEY_HEADER=Authorization
PAYMENT_PROVIDER_TIMEOUT_MS=10000

SHIPPING_PROVIDER_LABEL=Shipping gateway
SHIPPING_PROVIDER_CALLBACK_SECRET=replace-with-dedicated-random-secret
SHIPPING_PROVIDER_BASE_URL=https://replace-with-provider-base-url
SHIPPING_PROVIDER_REQUEST_PATH=/shipments/bookings
SHIPPING_PROVIDER_API_KEY=replace-with-provider-api-key
SHIPPING_PROVIDER_API_KEY_HEADER=Authorization
SHIPPING_PROVIDER_TIMEOUT_MS=10000

NOTIFICATION_PROVIDER_LABEL=Notification gateway
NOTIFICATION_PROVIDER_CALLBACK_SECRET=replace-with-dedicated-random-secret
NOTIFICATION_PROVIDER_BASE_URL=https://replace-with-provider-base-url
NOTIFICATION_PROVIDER_REQUEST_PATH=/notifications/send
NOTIFICATION_PROVIDER_API_KEY=replace-with-provider-api-key
NOTIFICATION_PROVIDER_API_KEY_HEADER=Authorization
NOTIFICATION_PROVIDER_TIMEOUT_MS=10000

DEPLOYMENT_COMMIT_SHA=
