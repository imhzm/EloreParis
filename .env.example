# Keep localhost only for local development. Set this to the final hosted domain before launch claims.
APP_ENV=local
NEXT_PUBLIC_SITE_URL=http://localhost:3056
# These release gates must remain false until the legal, catalog, content,
# provider, security, and release checks are explicitly approved. Commerce and
# indexing each derive from their own complete prerequisite set.
PUBLIC_RELEASE_APPROVED=false
PUBLIC_CATALOG_APPROVED=false
PUBLIC_DISCOVERY_CONTENT_APPROVED=false
PUBLIC_EDITORIAL_CONTENT_APPROVED=false
PUBLIC_LEGAL_CONTENT_APPROVED=false
PUBLIC_COMMERCE_ENABLED=false
HOSTING_PROVIDER=local
AUTHORITY_DB_PATH=.data/authority.sqlite
RELEASE_EVIDENCE_PATH=.artifacts/release-evidence.json
OPS_ACCESS_CODE=replace-with-a-strong-internal-ops-code
# Preferred identity-backed ops bootstrap for release and live deploy verification.
OPS_AUTH_USERS_JSON=[{"id":"ops-manager","name":"Ops manager","role":"manager","username":"ops.manager","passwordHash":"replace-with-output-from-ops-hash-password-script"}]
# Legacy transitional fallback only. Keep empty when OPS_AUTH_USERS_JSON is active.
OPS_ACCESS_USERS_JSON=[{"id":"ops-manager","name":"Ops manager","role":"manager","accessCode":"replace-me"}]
OPS_ACCESS_SIGNING_SECRET=replace-with-a-strong-ops-session-signing-secret
ENFORCE_OPS_ACCESS=false
OPS_AUDIT_FILE=.data/ops-audit.json
ORDER_AUTHORITY_SECRET=replace-with-a-strong-order-authority-secret
ORDER_AUTHORITY_FILE=.data/orders.json
NOTIFICATION_AUTHORITY_FILE=.data/notifications.json
# Provider callback HMAC signs the exact string: <unix-seconds>.<raw-json-body>.
# Keep false only for local legacy Bearer callback testing; production defaults to HMAC.
PROVIDER_CALLBACK_HMAC_REQUIRED=false
PROVIDER_CALLBACK_MAX_SKEW_SECONDS=300
LIFECYCLE_COLLECTION_ENABLED=false
LIFECYCLE_CONSENT_POLICY_VERSION=local-development-v1
LIFECYCLE_UNSUBSCRIBE_SECRET=replace-with-at-least-32-random-characters
LIFECYCLE_DELIVERY_ENABLED=false
LIFECYCLE_DELIVERY_PROVIDER_ENABLED=false
LIFECYCLE_DELIVERY_PROVIDER_KEY=unassigned
AUTH_PROVIDER_CALLBACK_SECRET=replace-with-a-dedicated-auth-callback-secret
AUTH_PROVIDER_LABEL=Customer identity provider
AUTH_PROVIDER_ISSUER=https://replace-with-auth-provider-issuer
AUTH_PROVIDER_AUTHORIZE_URL=https://replace-with-auth-provider-authorize-url
AUTH_PROVIDER_TOKEN_URL=https://replace-with-auth-provider-token-url
AUTH_PROVIDER_PROFILE_URL=https://replace-with-auth-provider-profile-url
AUTH_PROVIDER_CLIENT_ID=replace-with-auth-provider-client-id
AUTH_PROVIDER_CLIENT_SECRET=replace-with-auth-provider-client-secret
AUTH_PROVIDER_SCOPE=openid profile email phone
PAYMENT_PROVIDER_LABEL=Payment gateway
PAYMENT_PROVIDER_CALLBACK_SECRET=replace-with-payment-callback-secret
PAYMENT_PROVIDER_BASE_URL=https://replace-with-payment-provider-base-url
PAYMENT_PROVIDER_REQUEST_PATH=/payments/links
PAYMENT_PROVIDER_API_KEY=replace-with-payment-provider-api-key
PAYMENT_PROVIDER_API_KEY_HEADER=Authorization
PAYMENT_PROVIDER_TIMEOUT_MS=10000
SHIPPING_PROVIDER_LABEL=Shipping gateway
SHIPPING_PROVIDER_CALLBACK_SECRET=replace-with-shipping-callback-secret
SHIPPING_PROVIDER_BASE_URL=https://replace-with-shipping-provider-base-url
SHIPPING_PROVIDER_REQUEST_PATH=/shipments/bookings
SHIPPING_PROVIDER_API_KEY=replace-with-shipping-provider-api-key
SHIPPING_PROVIDER_API_KEY_HEADER=Authorization
SHIPPING_PROVIDER_TIMEOUT_MS=10000
NOTIFICATION_PROVIDER_LABEL=Notification gateway
NOTIFICATION_PROVIDER_CALLBACK_SECRET=replace-with-notification-callback-secret
NOTIFICATION_PROVIDER_CALLBACK_PATH=/api/providers/notifications
NOTIFICATION_PROVIDER_BASE_URL=https://replace-with-notification-provider-base-url
NOTIFICATION_PROVIDER_REQUEST_PATH=/notifications/send
NOTIFICATION_PROVIDER_API_KEY=replace-with-notification-provider-api-key
NOTIFICATION_PROVIDER_API_KEY_HEADER=Authorization
NOTIFICATION_PROVIDER_TIMEOUT_MS=10000
# Production Hostinger values are stored only in /etc/elore-paris/elore-paris.env.
# Never commit the live environment file or deployment credentials.
DEPLOYMENT_COMMIT_SHA=
# Version identifiers for the legally approved checkout documents. Required before quoting.
PUBLIC_TERMS_VERSION=
PUBLIC_PRIVACY_NOTICE_VERSION=
